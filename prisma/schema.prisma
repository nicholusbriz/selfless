// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ============================================
// AUTH & USER MANAGEMENT
// ============================================

// MAIN USER - Everyone has one account
model User {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  firstName   String
  lastName    String
  email       String   @unique
  password    String
  phoneNumber String?
  role        Role?    @relation(fields: [roleId], references: [id])
  roleId      String?  @db.ObjectId

  // Online Status
  status      String   @default("OFFLINE") // ONLINE, OFFLINE, AWAY
  lastSeen    DateTime? // Nullable for existing users

  // Location Information
  country     String?  @default("Uganda") // Uganda or Liberia
  city        String?
  town        String?
  street      String?

  // Academic Information
  generalCourse String? // General course being taken
  techCenter    String? @default("Freedom City Tech Center") // Tech center name

  // Social Links (displayed as text, not clickable)
  linkedinUrl String?
  githubUrl   String?
  projectUrls String[] // Array of project links

  // Profile Image (stored in Supabase Storage)
  profileImageUrl String? // Public URL from Supabase Storage

  // Student specific
  studentProfile StudentProfile?

  // Teacher specific
  teacherProfile TeacherProfile?

  // Admin specific
  adminProfile AdminProfile?

  // Assignments where this user is a teacher
  teachingAssignments TeacherStudentAssignment[] @relation("TeacherAssignments")

  // Assignments where this user is a student
  studentAssignments TeacherStudentAssignment[] @relation("StudentAssignments")

  // Cleaning Management
  cleaningRegistration CleaningRegistration?
  attendanceRecords    AttendanceRecord[]

  // Announcements
  announcements         Announcement[]

  // Messaging
  sentMessages          Message[] @relation("MessageSender")
  receivedMessages      Message[] @relation("MessageReceiver")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("users")
}

// ROLES - Simple role-based access control
model Role {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String   @unique  // "admin", "teacher", "student"
  permissions String[]
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("roles")
}

// ============================================
// USER PROFILES
// ============================================

// STUDENT PROFILE - Academic tracking (every user has one)
model StudentProfile {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  userId       String   @unique @db.ObjectId
  user         User     @relation(fields: [userId], references: [id])
  studentId    String   @unique  // Format: STU2024001
  takesReligion Boolean @default(false)
  tuition      Float?
  tuitionPaid  Boolean  @default(false)
  currentGPA   Float    @default(0)
  totalCredits Int      @default(0)
  enrolledCourses EnrolledCourse[]
  grades       Grade[]

  @@map("student_profiles")
}

// TEACHER PROFILE - Teaching capabilities (only for teachers)
model TeacherProfile {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @unique @db.ObjectId
  user       User     @relation(fields: [userId], references: [id])
  teacherId  String   @unique  // Format: TCH2024001
  department String?
  assignedAt DateTime @default(now())
  
  @@map("teacher_profiles")
}

// ADMIN PROFILE - Admin capabilities (only for admins)
model AdminProfile {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @unique @db.ObjectId
  user      User     @relation(fields: [userId], references: [id])
  adminId   String   @unique  // Format: ADM2024001
  promotedAt DateTime @default(now())
  notes     String?
  
  @@map("admin_profiles")
}

// ============================================
// ACADEMIC TRACKING
// ============================================

// ENROLLED COURSES - Every student's courses
model EnrolledCourse {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  studentId   String   @db.ObjectId
  student     StudentProfile @relation(fields: [studentId], references: [id])
  courseName  String
  credits     Int
  status      String   @default("active")
  submittedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  grades      Grade[]
  
  @@map("enrolled_courses")
}

// GRADES - Academic performance tracking
model Grade {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  studentId   String   @db.ObjectId
  student     StudentProfile @relation(fields: [studentId], references: [id])
  courseId    String   @db.ObjectId
  course      EnrolledCourse @relation(fields: [courseId], references: [id])
  week        Int
  gradeLetter String
  gradePoints Float
  assignedBy  String   @db.ObjectId
  assignedAt  DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([studentId, courseId, week])
  @@index([week, gradeLetter])
  @@map("grades")
}

// TEACHER-STUDENT ASSIGNMENT
model TeacherStudentAssignment {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  teacherId   String   @db.ObjectId
  studentId   String   @db.ObjectId
  status      String   @default("not_verified")
  notes       String?
  assignedAt  DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  teacher     User     @relation("TeacherAssignments", fields: [teacherId], references: [id])
  student     User     @relation("StudentAssignments", fields: [studentId], references: [id])
  
  @@unique([teacherId, studentId])
  @@index([teacherId])
  @@index([studentId])
  @@index([status])
  @@map("teacher_student_assignments")
}

// ============================================
// CONTACT & MESSAGING
// ============================================

// CONTACT MESSAGES
model ContactMessage {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  email       String
  phoneNumber String?
  message     String
  status      String   @default("unread")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([status])
  @@index([createdAt])
  @@map("contact_messages")
}

// ANNOUNCEMENTS - Student announcements
model Announcement {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  content     String
  authorId    String   @db.ObjectId
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([authorId])
  @@index([createdAt])
  @@map("announcements")
}

// ============================================
// CLEANING MANAGEMENT SYSTEM
// ============================================

// WEEK - Container for cleaning days (Mon-Fri)
model Week {
  id                    String   @id @default(auto()) @map("_id") @db.ObjectId
  startDate             DateTime
  endDate               DateTime
  weekLabel             String?
  isActive              Boolean  @default(true)
  registrationEnabled   Boolean  @default(true)
  registrationDeadline  DateTime
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  days                  CleaningDay[]
  
  @@index([isActive])
  @@map("weeks")
}

// CLEANING DAY - Individual cleaning day
model CleaningDay {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  weekId              String   @db.ObjectId
  week                Week     @relation(fields: [weekId], references: [id], onDelete: Cascade)
  dayOfWeek           String   // Monday, Tuesday, Wednesday, Thursday, Friday
  cleaningDate        DateTime
  capacityLimit       Int      @default(0)
  currentRegistrations Int     @default(0)
  isOpen              Boolean  @default(true)
  isFull              Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  
  registrations       CleaningRegistration[]
  attendanceRecords   AttendanceRecord[]
  
  @@index([cleaningDate])
  @@map("cleaning_days")
}

// CLEANING REGISTRATION - Links student to cleaning day (ONE student = ONE day globally)
model CleaningRegistration {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @unique  // One student = One day globally
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cleaningDayId String   @db.ObjectId
  cleaningDay   CleaningDay @relation(fields: [cleaningDayId], references: [id], onDelete: Cascade)
  registeredAt  DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([cleaningDayId])
  @@map("cleaning_registrations")
}

// ATTENDANCE RECORD - Tracks attendance status
model AttendanceRecord {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @db.ObjectId
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cleaningDayId String   @db.ObjectId
  cleaningDay   CleaningDay @relation(fields: [cleaningDayId], references: [id], onDelete: Cascade)
  status        AttendanceStatus @default(PENDING)
  markedBy      String?  @db.ObjectId
  markedAt      DateTime @default(now())
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@unique([userId, cleaningDayId])
  @@index([cleaningDayId])
  @@index([status])
  @@map("attendance_records")
}

// ATTENDANCE STATUS ENUM
enum AttendanceStatus {
  PENDING
  ATTENDED
  NO_SHOW
}

// ============================================
// MESSAGING SYSTEM
// ============================================

// CONVERSATION - Chat conversation between users
model Conversation {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  participantIds  String[]
  lastMessageId   String?  @db.ObjectId
  messages        Message[]
  unreadCount     Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("conversations")
}

// MESSAGE - Individual message in a conversation
model Message {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  content         String
  senderId        String   @db.ObjectId
  sender          User     @relation("MessageSender", fields: [senderId], references: [id])
  receiverId      String   @db.ObjectId
  receiver        User     @relation("MessageReceiver", fields: [receiverId], references: [id])
  conversationId  String   @db.ObjectId
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  isRead          Boolean  @default(false)
  readAt          DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("messages")
}