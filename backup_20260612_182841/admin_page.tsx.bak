'use client';

import { useState, useMemo } from 'react';
import { useAuthStore } from '@/stores/authStore';
import { ToastContainer, Toast, ToastType } from '@/components/ui/Toast';
import { useAdminStudents, useGPADistribution, useWeeklyProgress, useUpdateTuitionStatus, useUpdateUserRole, useRoles, useDeleteStudent } from '@/hooks/queries/admin';
import { useAssignGrade } from '@/hooks/queries/teacher';
import { useAssignments, useTeachers, useCreateAssignment, useDeleteAssignment, useUpdateAssignment } from '@/hooks/queries/assignments';
import OverviewTab from './ui/OverviewTab';
import StudentsTab from './ui/StudentsTab';
import GradesTab from './ui/GradesTab';
import TuitionTab from './ui/TuitionTab';
import ReportsTab from './ui/ReportsTab';
import AssignmentsTab from './ui/AssignmentsTab';

type Tab = 'overview' | 'students' | 'grades' | 'reports' | 'tuition' | 'assignments';

export default function AdminDashboard() {
  const { user } = useAuthStore();
  const [activeTab, setActiveTab] = useState<Tab>('overview');
  const [selectedWeek, setSelectedWeek] = useState(1);
  const [filters, setFilters] = useState<any>({});
  const [gpaFilter, setGpaFilter] = useState<{ min: number; max: number } | null>(null);
  const [selectedTeacherFilter, setSelectedTeacherFilter] = useState<string | null>(null);
  const [showAssignModal, setShowAssignModal] = useState(false);
  const [assignForm, setAssignForm] = useState({ teacherId: '', studentId: '', notes: '' });
  const [selectedTeacherForBulk, setSelectedTeacherForBulk] = useState<string | null>(null);
  const [selectedStudentsForBulk, setSelectedStudentsForBulk] = useState<Set<string>>(new Set());
  const [toasts, setToasts] = useState<Toast[]>([]);

  const showToast = (message: string, type: ToastType = 'info') => {
    const id = Date.now().toString();
    setToasts((prev) => [...prev, { id, message, type }]);
  };

  const closeToast = (id: string) => {
    setToasts((prev) => prev.filter((toast) => toast.id !== id));
  };

  // TanStack Query hooks
  const { data: studentsData, isLoading: studentsLoading, error: studentsError, refetch } = useAdminStudents();
  const { data: gpaDistData, isLoading: gpaLoading } = useGPADistribution();
  const { data: weeklyProgressData, isLoading: weeklyLoading } = useWeeklyProgress();
  const assignGradeMutation = useAssignGrade();
  const updateTuitionMutation = useUpdateTuitionStatus();
  const updateRoleMutation = useUpdateUserRole();
  const deleteStudentMutation = useDeleteStudent();
  const { data: rolesData } = useRoles();
  
  // Assignment hooks
  const { data: assignmentsData, isLoading: assignmentsLoading, refetch: refetchAssignments } = useAssignments(
    selectedTeacherFilter ? { teacherId: selectedTeacherFilter } : undefined
  );
  const { data: teachersData, isLoading: teachersLoading } = useTeachers();
  const createAssignmentMutation = useCreateAssignment();
  const deleteAssignmentMutation = useDeleteAssignment();
  const updateAssignmentMutation = useUpdateAssignment();

  // Map students data
  const students = useMemo(() => {
    if (!studentsData?.students) return [];
    
    return studentsData.students.map((student: any) => ({
      id: student.id,
      name: student.name,
      studentId: student.studentId,
      email: student.email,
      roleId: student.roleId,
      role: student.role,
      currentGPA: student.currentGPA,
      totalCredits: student.totalCredits,
      coursesCount: student.coursesCount,
      tuition: student.tuition,
      tuitionPaid: student.tuitionPaid,
      enrolledCourses: student.enrolledCourses || [],
      existingGrades: student.grades || []
    }));
  }, [studentsData]);
  
  const gpaDistribution = gpaDistData?.distribution;
  const weeklyProgress = weeklyProgressData?.weeklyProgress || [];

  // Filter students
  const filteredStudents = useMemo(() => {
    let filtered = [...students];

    if (filters.search) {
      const search = filters.search.toLowerCase();
      filtered = filtered.filter((s: any) =>
        s.name.toLowerCase().includes(search) ||
        s.studentId.toLowerCase().includes(search)
      );
    }

    if (gpaFilter) {
      filtered = filtered.filter((s: any) => s.currentGPA >= gpaFilter.min && s.currentGPA < gpaFilter.max);
    }

    return filtered;
  }, [students, filters, gpaFilter]);

  // Handlers
  const handleGradeAssign = async (studentId: string, courseId: string, gradeLetter: string) => {
    try {
      await assignGradeMutation.mutateAsync({
        studentId,
        courseId,
        week: selectedWeek,
        gradeLetter
      });
      refetch();
      showToast('Grade assigned successfully', 'success');
    } catch (error) {
      console.error('Error assigning grade:', error);
      showToast('Failed to assign grade', 'error');
    }
  };

  const handleFilterChange = (newFilters: any) => {
    setFilters(newFilters);
  };

  const handleGpaFilter = (min: number, max: number) => {
    if (min === 0 && max === 4.0) {
      setGpaFilter(null);
    } else {
      setGpaFilter({ min, max });
    }
  };

  const handleTuitionToggle = async (studentId: string, currentStatus: boolean) => {
    try {
      await updateTuitionMutation.mutateAsync({
        studentId,
        tuitionPaid: !currentStatus
      });
      showToast(`Tuition status updated to ${!currentStatus ? 'Paid' : 'Pending'}`, 'success');
    } catch (error) {
      console.error('Error updating tuition status:', error);
      showToast('Failed to update tuition status', 'error');
    }
  };

  const handleRoleChange = async (userId: string, roleId: string) => {
    try {
      await updateRoleMutation.mutateAsync({ userId, roleId });
      showToast('Student role updated successfully', 'success');
      refetch();
    } catch (error) {
      console.error('Error updating user role:', error);
      showToast('Failed to update student role', 'error');
    }
  };

  const handleDeleteStudent = async (studentId: string, studentName: string) => {
    if (!confirm(`Are you sure you want to delete ${studentName}? This action cannot be undone.`)) {
      return;
    }
    try {
      await deleteStudentMutation.mutateAsync(studentId);
      showToast(`${studentName} deleted successfully`, 'success');
    } catch (error) {
      console.error('Error deleting student:', error);
      showToast('Failed to delete student', 'error');
    }
  };

  const handleUpdateAssignmentStatus = async (assignmentId: string, status: string) => {
    try {
      await updateAssignmentMutation.mutateAsync({ id: assignmentId, data: { status } });
      showToast('Assignment status updated successfully', 'success');
      refetchAssignments();
    } catch (error) {
      console.error('Error updating assignment status:', error);
      showToast('Failed to update assignment status', 'error');
    }
  };

  const handleDeleteAssignment = async (assignmentId: string) => {
    try {
      await deleteAssignmentMutation.mutateAsync(assignmentId);
      showToast('Assignment deleted successfully', 'success');
      refetchAssignments();
    } catch (error) {
      console.error('Error deleting assignment:', error);
      showToast('Failed to delete assignment', 'error');
    }
  };

  const handleCreateAssignment = async (e: React.FormEvent) => {
    e.preventDefault();
    try {
      await createAssignmentMutation.mutateAsync({
        teacherId: assignForm.teacherId,
        studentId: assignForm.studentId,
        notes: assignForm.notes
      });
      setShowAssignModal(false);
      setAssignForm({ teacherId: '', studentId: '', notes: '' });
      showToast('Assignment created successfully', 'success');
      refetchAssignments();
    } catch (error) {
      console.error('Error creating assignment:', error);
      showToast('Failed to create assignment', 'error');
    }
  };

  const handleBulkAssign = async () => {
    if (!selectedTeacherForBulk || selectedStudentsForBulk.size === 0) return;
    try {
      for (const studentId of selectedStudentsForBulk) {
        await createAssignmentMutation.mutateAsync({
          teacherId: selectedTeacherForBulk,
          studentId,
          notes: 'Bulk assignment'
        });
      }
      setSelectedStudentsForBulk(new Set());
      setSelectedTeacherForBulk(null);
      refetchAssignments();
      showToast('Bulk assignment completed', 'success');
    } catch (error) {
      console.error('Error creating bulk assignments:', error);
      showToast('Failed to create bulk assignments', 'error');
    }
  };

  const handleBulkRemove = async () => {
    if (!selectedTeacherForBulk || selectedStudentsForBulk.size === 0) return;
    try {
      for (const studentId of selectedStudentsForBulk) {
        const assignment = assignmentsData?.assignments?.find(
          (a: any) => a.teacherId === selectedTeacherForBulk && a.studentId === studentId
        );
        if (assignment) {
          await deleteAssignmentMutation.mutateAsync(assignment.id);
        }
      }
      setSelectedStudentsForBulk(new Set());
      refetchAssignments();
      showToast('Bulk removal completed', 'success');
    } catch (error) {
      console.error('Error removing bulk assignments:', error);
      showToast('Failed to remove bulk assignments', 'error');
    }
  };

  const toggleStudentSelection = (studentId: string) => {
    if (studentId === 'clear') {
      setSelectedStudentsForBulk(new Set());
      return;
    }
    const newSelection = new Set(selectedStudentsForBulk);
    if (newSelection.has(studentId)) {
      newSelection.delete(studentId);
    } else {
      newSelection.add(studentId);
    }
    setSelectedStudentsForBulk(newSelection);
  };

  const totalStudents = students.length;
  const averageGPA = students.length > 0
    ? students.reduce((sum: number, s: any) => sum + (s.currentGPA || 0), 0) / students.length
    : 0;

  const teachers = teachersData?.teachers || [];
  const assignments = assignmentsData?.assignments || [];

  return (
    <div className="flex flex-col h-full">
      {/* Tabs */}
      <div className="flex gap-2 mb-6 flex-shrink-0 overflow-x-auto pb-2">
        {[
          { id: 'overview' as Tab, label: 'Overview' },
          { id: 'students' as Tab, label: 'Manage Students' },
          { id: 'grades' as Tab, label: 'Manage Grades' },
          { id: 'assignments' as Tab, label: 'Assignments' },
          { id: 'tuition' as Tab, label: 'Tuition' },
          { id: 'reports' as Tab, label: 'Reports' },
        ].map((tab) => (
          <button
            key={tab.id}
            onClick={() => setActiveTab(tab.id)}
            className={`px-4 py-2 rounded-lg font-medium whitespace-nowrap transition-colors ${
              activeTab === tab.id
                ? 'bg-gradient-to-r from-violet-600 to-indigo-600 text-white'
                : 'bg-white/5 border border-white/10 text-gray-300 hover:bg-white/10'
            }`}
          >
            {tab.label}
          </button>
        ))}
      </div>

      {/* Tab Content */}
      <div className="flex-1 overflow-y-auto">
        {activeTab === 'overview' && (
          <OverviewTab
            students={students}
            filteredStudents={filteredStudents}
            studentsLoading={studentsLoading}
            studentsError={studentsError}
            totalStudents={totalStudents}
            averageGPA={averageGPA}
            onGpaFilter={handleGpaFilter}
          />
        )}
        {activeTab === 'students' && (
          <StudentsTab
            filteredStudents={filteredStudents}
            studentsLoading={studentsLoading}
            studentsError={studentsError}
            deleteStudentPending={deleteStudentMutation.isPending}
            updateRolePending={updateRoleMutation.isPending}
            rolesData={rolesData}
            onFilterChange={handleFilterChange}
            onDeleteStudent={handleDeleteStudent}
            onRoleChange={handleRoleChange}
          />
        )}
        {activeTab === 'grades' && (
          <GradesTab
            students={students}
            selectedWeek={selectedWeek}
            studentsLoading={studentsLoading}
            studentsError={studentsError}
            onWeekChange={setSelectedWeek}
            onGradeAssign={handleGradeAssign}
            onRefresh={() => refetch()}
          />
        )}
        {activeTab === 'tuition' && (
          <TuitionTab
            students={students}
            studentsLoading={studentsLoading}
            onTuitionToggle={handleTuitionToggle}
            updatePending={updateTuitionMutation.isPending}
          />
        )}
        {activeTab === 'reports' && (
          <ReportsTab
            gpaDistribution={gpaDistribution}
            weeklyProgress={weeklyProgress}
            gpaLoading={gpaLoading}
            weeklyLoading={weeklyLoading}
          />
        )}
        {activeTab === 'assignments' && (
          <AssignmentsTab
            assignments={assignments}
            teachers={teachers}
            students={students}
            assignmentsLoading={assignmentsLoading}
            teachersLoading={teachersLoading}
            studentsLoading={studentsLoading}
            selectedTeacherFilter={selectedTeacherFilter}
            selectedTeacherForBulk={selectedTeacherForBulk}
            selectedStudentsForBulk={selectedStudentsForBulk}
            showAssignModal={showAssignModal}
            assignForm={assignForm}
            onSetSelectedTeacherFilter={setSelectedTeacherFilter}
            onSetSelectedTeacherForBulk={setSelectedTeacherForBulk}
            onToggleStudentSelection={toggleStudentSelection}
            onSetShowAssignModal={setShowAssignModal}
            onSetAssignForm={setAssignForm}
            onBulkAssign={handleBulkAssign}
            onBulkRemove={handleBulkRemove}
            onCreateAssignment={handleCreateAssignment}
            onUpdateAssignmentStatus={handleUpdateAssignmentStatus}
            onDeleteAssignment={handleDeleteAssignment}
          />
        )}
      </div>
      
      <ToastContainer toasts={toasts} onClose={closeToast} />
    </div>
  );
}